APP_NAME=Tabular AI Agent
APP_ENV=dev
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/tabular_agent
REDIS_URL=redis://redis:6379/0
QUEUE_NAME=transform_jobs
LLM_PROVIDER=deepseek
LLM_API_KEY=your_deepseek_api_key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_INPUT_1K_TOKEN_PRICE_USD=0.00014
LLM_OUTPUT_1K_TOKEN_PRICE_USD=0.00028
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=false
KEYCLOAK_ENABLED=false
KEYCLOAK_ISSUER=http://localhost:8081/realms/tabular-agent
KEYCLOAK_BROWSER_ISSUER=http://localhost:8081/realms/tabular-agent
KEYCLOAK_BACKCHANNEL_ISSUER=http://keycloak:8080/realms/tabular-agent
KEYCLOAK_CLIENT_ID=tabular-ai-agent
KEYCLOAK_AUDIENCE=tabular-ai-agent
SESSION_SECRET_KEY=change-me
SESSION_COOKIE_NAME=tabular_ai_session
SESSION_MAX_AGE_SECONDS=28800
SESSION_COOKIE_SECURE=false
UPLOAD_DIR=/app/storage/uploads
RESULT_DIR=/app/storage/results
SANDBOX_IMAGE=tabular-agent-sandbox:latest
SANDBOX_TIMEOUT_SECONDS=15
MAX_REPAIR_ATTEMPTS=3
FOOFAH_MAX_REPAIR_ATTEMPTS=5
